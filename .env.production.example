# Production example only. Do not commit real production secrets.

NODE_ENV="production"

# Public URLs
FRONTEND_URL="https://app.example.com"
NEXT_PUBLIC_API_URL="https://api.example.com/api"

# Backend
PORT=4000
TRUST_PROXY="true"
UPLOAD_DIR="/app/uploads"
MAX_UPLOAD_BYTES="5242880"
LOG_LEVEL="info"
COOKIE_DOMAIN=".example.com"

# PostgreSQL
DATABASE_URL="postgresql://atlas_prod_user:replace-with-strong-password@postgres.example.com:5432/atlas_suite?schema=public"

# Redis
REDIS_URL="redis://redis.example.com:6379"
QUEUE_PREFIX="atlas"
RATE_LIMIT_FAIL_OPEN="false"

# Auth
JWT_SECRET="replace-with-at-least-32-random-characters"
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL_DAYS="30"
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES="60"
PASSWORD_RESET_TOKEN_TTL_MINUTES="15"
